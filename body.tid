<$list filter="[all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>field:dash-parent<currentTiddler>]" variable="dashChild">
<$action-setfield $tiddler=<<dashChild>> dash-parent={{!!dash-parent}}/>
