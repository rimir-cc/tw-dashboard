\procedure dash-value()
<%if [<dvImg>match[yes]] %>
<img class="rr-dash-tile-img" src=<<dvVal>> draggable="false" loading="lazy"/>
<%else%>
<%if [<dvVal>is[tiddler]] [<dvVal>is[shadow]] %>
<%if [<dvVal>has[_thumbnail_uri]] %>
<img class="rr-dash-tile-img" src={{{ [<dvVal>get[_thumbnail_uri]] }}} draggable="false" loading="lazy"/>
<%else%>
<$transclude $tiddler=<<dvVal>> $mode=<<dvMode>>/>
<%endif%>
<%else%>
<$transclude $tiddler=<<dvTid>> $field=<<dvField>> $mode=<<dvMode>>/>
<%endif%>
<%endif%>
\end

\procedure dash-tile-content()
<%if [<displayField>match[text]] [<displayField>match[body]] %>
<$tiddler tiddler=<<tileTarget>>>
<$transclude $mode="block"/>
</$tiddler>
<%else%>
<$let dvTid=<<tileTarget>> dvField=<<displayField>> dvMode="block" dvVal={{{ [<tileTarget>get<displayField>] }}} dvImg={{{ [<displayField>match[_thumbnail_uri]then[yes]] ~[<tileTarget>get[type]prefix[image/]then<displayField>match[_canonical_uri]then[yes]] ~[[no]] }}} dvClass={{{ [<dvImg>match[yes]then[rr-dash-tile-icon]] ~[<dvVal>is[tiddler]then[rr-dash-tile-icon]] ~[<dvVal>is[shadow]then[rr-dash-tile-icon]] ~[[rr-dash-tile-field]] }}}>
<div class=<<dvClass>>><<dash-value>></div>
</$let>
<%endif%>
\end

\procedure dash-tile-body()
<$let tileTarget={{!!target}}
	dashRuleField={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/display-rule]field:dashboard<dashId>nsort[order]] :map[<tileTarget>subfilter{!!filter}first[]then{!!field}] +[!is[blank]first[]] }}}
	displayField={{{ [<currentTiddler>get[display]!is[blank]] ~[<dashRuleField>!is[blank]] ~[<tileTarget>has[_thumbnail_uri]then[_thumbnail_uri]] ~[<tileTarget>has[text]then[text]] ~[<tileTarget>has[icon]then[icon]] ~[[text]] }}}
	fzTarget={{!!target}} fzContainer=<<containerId>>>
<%if [<hasFileUpload>match[yes]] %>
