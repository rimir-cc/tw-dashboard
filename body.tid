\procedure dash-collapse-toggle()
<$button class="rr-dash-ctl rr-dash-no-drag" tooltip="Collapse / expand this tile" aria-label="Collapse or expand tile">
<$action-setfield $tiddler=<<currentTiddler>> collapsed={{{ [<collapsed>match[yes]then[no]] ~[[yes]] }}}/>
<$list filter="[<collapsed>match[yes]]" variable="ignore">
<$action-setfield $tiddler=<<currentTiddler>> z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>get[z]nsort[]last[]add[1]] ~[[1]] }}}/>
</$list>
<%if [<collapsed>match[yes]] %>▸<%else%>▾<%endif%>
</$button>
\end

\procedure dash-group-handle()
<div class="rr-dash-handle">
<%if [<iconOnly>match[yes]] %>
<span class="rr-dash-title rr-dash-group-icononly" title={{{ [{!!caption}!is[blank]] ~[[Group]] }}}>
<span class="rr-dash-group-icon rr-dash-group-icon-lg" style=<<iconStyle>>><<dash-value>></span>
</span>
<%else%>
<$droppable tag="div" class="rr-dash-ctx-drop" actions=<<dashContextActions>>>
<span class="rr-dash-title">
<<dash-collapse-toggle>>
<<dash-group-context>>
<$list filter="[<groupIcon>!is[blank]]" variable="ignore">
<span class="rr-dash-group-icon rr-dash-group-icon-sm"><<dash-value>></span>
</$list>
<$edit-text tiddler=<<currentTiddler>> field="caption" tag="input" default="" placeholder="Group" focus={{{ [{$:/state/rimir/dashboard/focus-group}match<currentTiddler>then[yes]] }}} class="rr-dash-group-name rr-dash-no-drag tc-edit-texteditor"/>
<span class="rr-dash-count">(<$count filter="[all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>field:dash-parent<currentTiddler>]"/>)</span>
</span>
</$droppable>
<%endif%>
<span class="rr-dash-controls"><$let emenuEntity=<<groupContext>> emenuCtxB=<<currentTiddler>>><<dash-emenu>></$let><<dash-group-controls>></span>
</div>
\end

\procedure dash-content-handle()
<div class="rr-dash-handle">
<%if [<cIconOnly>match[yes]] %>
<span class="rr-dash-title rr-dash-group-icononly" title={{{ [<tileTargetTitle>get[caption]!is[blank]] ~[<tileTargetTitle>] }}}>
<span class="rr-dash-group-icon rr-dash-group-icon-lg" style=<<iconStyle>>><<dash-value>></span>
</span>
<%else%>
<span class="rr-dash-title"><<dash-collapse-toggle>><<dash-title>></span>
<%endif%>
<span class="rr-dash-controls"><<dash-controls>></span>
</div>
\end

\procedure dash-content-tile()
<$let tileStyle={{{ [{!!style}match[bare]then[bare]] ~[[window]] }}}
	tileTargetTitle={{!!target}}
	tileExtUrl={{{ [enlist{$:/config/rimir/dashboard/external-open-fields}] :map[<tileTargetTitle>get<currentTiddler>] +[!is[blank]first[]] }}}
	collapsed={{{ [{!!collapsed}match[yes]then[yes]] ~[[no]] }}}
	cIconOnly={{{ [<collapsed>match[yes]] :filter[<tileTargetTitle>has[icon]] +[first[]then[yes]] ~[[no]] }}}
	collapsedDrop={{{ [<hasFileUpload>match[yes]] :filter[<collapsed>match[yes]] +[first[]then[yes]] ~[[no]] }}}
	iconW={{{ [{!!icon-w}trim[]!is[blank]] ~[{$:/config/rimir/dashboard/group-icon-max-width}trim[]!is[blank]] ~[[64]] }}}
	iconH={{{ [{!!icon-h}trim[]!is[blank]] ~[{$:/config/rimir/dashboard/group-icon-max-height}trim[]!is[blank]] ~[[64]] }}}
	iconStyle={{{ [<iconW>addprefix[width:]addsuffix[px; height:]addsuffix<iconH>addsuffix[px;]] }}}
	dvTid=<<tileTargetTitle>> dvField="icon" dvMode="inline" dvImg="no" dvVal={{{ [<tileTargetTitle>get[icon]] }}}
	dashContentExpand="""<$list filter="[<currentTiddler>get[collapsed]match[yes]]" variable="ignore"><$action-setfield $tiddler=<<currentTiddler>> collapsed="no" z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard{!!dashboard}get[z]nsort[]last[]add[1]] ~[[1]] }}}/></$list>""">
<%if [<tileStyle>match[bare]] %>
<$dashboard-drag tile=<<currentTiddler>> x={{!!x}} y={{!!y}} w={{!!w}} h={{!!h}} z={{!!z}} move-selector="" class="rr-dash-box rr-dash-bare" container={{{ [<currentTiddler>get[dash-parent]] }}} dash-id=<<dashId>> actions=<<dashGeomActions>> reparent-actions=<<dashReparentActions>> copy-actions=<<dashCopyActions>> open-actions=<<dashOpenActions>> ctrl-open-url=<<tileExtUrl>>>
<div class="rr-dash-controls rr-dash-no-drag"><<dash-controls>></div>
<div class="rr-dash-body"><<dash-tile-body>></div>
<div class="rr-dash-resize"></div>
</$dashboard-drag>
<%else%>
<$dashboard-drag tile=<<currentTiddler>> x={{!!x}} y={{!!y}} w={{!!w}} h={{!!h}} z={{!!z}} icon-w=<<iconW>> icon-h=<<iconH>> move-selector=".rr-dash-handle" class="rr-dash-box" container={{{ [<currentTiddler>get[dash-parent]] }}} dash-id=<<dashId>> actions=<<dashGeomActions>> reparent-actions=<<dashReparentActions>> copy-actions=<<dashCopyActions>> open-actions={{{ [<collapsed>match[yes]then<dashContentExpand>] ~[<dashOpenActions>] }}} size-actions=<<dashSizeActions>> ctrl-open-url=<<tileExtUrl>> fit-width={{{ [<cIconOnly>match[yes]then[yes]] }}} fit-height={{{ [<collapsed>match[yes]then[yes]] }}}>
<%if [<collapsedDrop>match[yes]] %>
<$let fzTarget=<<tileTargetTitle>> fzContainer=<<containerId>>>
<$file-dropzone class="rr-dash-collapsed-droptarget-fz" tabindex="0" location={{{ [<fzTarget>function[dash.fz-location],<fzTarget>] ~[[files]] }}} subfolder={{{ [<fzTarget>function[dash.fz-subfolder],<fzTarget>] }}} actions=<<dashTilePasteActions>>>
<<dash-content-handle>>
<<dash-paste-btn>>
</$file-dropzone>
</$let>
<%else%>
<<dash-content-handle>>
<%endif%>
<%if [<cIconOnly>match[yes]] %>
<div class="rr-dash-resize rr-dash-resize-icon" title="Drag to resize this icon"></div>
<%endif%>
<%if [<collapsed>match[no]] %>
<div class="rr-dash-body"><<dash-tile-body>></div>
<div class="rr-dash-resize"></div>
<%endif%>
</$dashboard-drag>
<%endif%>
</$let>
\end

\procedure dash-group-tile()
<$let collapsed={{{ [{!!collapsed}match[yes]then[yes]] ~[[no]] }}}
	groupContext={{!!dash-context}}
	groupIcon={{!!icon}}
	iconOnly={{{ [<collapsed>match[yes]] :filter[<groupIcon>!is[blank]] +[first[]then[yes]] ~[[no]] }}}
	iconW={{{ [{!!icon-w}trim[]!is[blank]] ~[{$:/config/rimir/dashboard/group-icon-max-width}trim[]!is[blank]] ~[[64]] }}}
	iconH={{{ [{!!icon-h}trim[]!is[blank]] ~[{$:/config/rimir/dashboard/group-icon-max-height}trim[]!is[blank]] ~[[64]] }}}
	iconStyle={{{ [<iconW>addprefix[width:]addsuffix[px; height:]addsuffix<iconH>addsuffix[px;]] }}}
	dvTid=<<currentTiddler>> dvField="icon" dvMode="inline" dvImg="no" dvVal={{!!icon}}
	dashGroupExpand="""<$list filter="[<currentTiddler>get[collapsed]match[yes]]" variable="ignore"><$action-setfield $tiddler=<<currentTiddler>> collapsed="no" z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard{!!dashboard}get[z]nsort[]last[]add[1]] ~[[1]] }}}/></$list>""">
<$dashboard-drag tile=<<currentTiddler>> x={{!!x}} y={{!!y}} w={{!!w}} h={{!!h}} z={{!!z}} icon-w=<<iconW>> icon-h=<<iconH>> move-selector=".rr-dash-handle" class="rr-dash-box rr-dash-group" container={{{ [<currentTiddler>get[dash-parent]] }}} dash-id=<<dashId>> actions=<<dashGeomActions>> reparent-actions=<<dashReparentActions>> open-actions=<<dashGroupExpand>> size-actions=<<dashSizeActions>> fit-width={{{ [<collapsed>match[yes]then[yes]] }}} fit-height={{{ [<collapsed>match[yes]then[yes]] }}}>
<%if [<collapsed>match[yes]] %>
<$let containerId=<<currentTiddler>> fzTarget=<<groupContext>> fzContainer=<<currentTiddler>>>
<$droppable tag="div" class="rr-dash-collapsed-droptarget" actions={{{ [<dashAddChildActions>addsuffix<dashExpandAction>] }}}>
<%if [<hasFileUpload>match[yes]] %>
<$file-dropzone class="rr-dash-collapsed-droptarget-fz" tabindex="0" location={{{ [<fzTarget>function[dash.fz-location],<fzTarget>] ~[[files]] }}} subfolder={{{ [<fzTarget>function[dash.fz-subfolder],<fzTarget>] }}} actions={{{ [<dashTilePasteActions>addsuffix<dashExpandAction>] }}}>
<<dash-group-handle>>
<<dash-paste-btn>>
</$file-dropzone>
<%else%>
<<dash-group-handle>>
<%endif%>
</$droppable>
</$let>
<%else%>
<<dash-group-handle>>
<%endif%>
<%if [<iconOnly>match[yes]] %>
<div class="rr-dash-resize rr-dash-resize-icon" title="Drag to resize this icon"></div>
<%endif%>
<%if [<collapsed>match[no]] %>
<div class="rr-dash-body rr-dash-group-body"><$transclude $variable="dash-canvas" containerId=<<currentTiddler>> $mode="block"/></div>
<div class="rr-dash-resize"></div>
<%endif%>
</$dashboard-drag>
</$let>
\end

\procedure dash-tile()
<%if [{!!role}match[group]] %>
<<dash-group-tile>>
<%else%>
<<dash-content-tile>>
<%endif%>
\end

\procedure dash-tiles(containerId)
<%if [<containerId>is[blank]] %>
<$list filter="[all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>!has[dash-parent]nsort[z]]" variable="currentTiddler" emptyMessage=<<dashEmptyHint>>>
<<dash-tile>>
</$list>
<%else%>
<$list filter="[all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>field:dash-parent<containerId>nsort[z]]" variable="currentTiddler" emptyMessage=<<dashEmptyHint>>>
<<dash-tile>>
</$list>
<%endif%>
\end

\procedure dash-canvas(containerId)
<$droppable tag="div" class="rr-dash-canvas" data-dash-parent=<<containerId>> data-dash-id=<<dashId>> actions=<<dashAddChildActions>>>
<%if [<hasFileUpload>match[yes]] %>
<$let fzTarget={{{ [<containerId>get[dash-context]] }}} fzContainer=<<containerId>>>
<$file-dropzone class="rr-dash-filezone" tabindex="0" location={{{ [<fzTarget>function[dash.fz-location],<fzTarget>] ~[[files]] }}} subfolder={{{ [<fzTarget>function[dash.fz-subfolder],<fzTarget>] }}} actions=<<dashTilePasteActions>>>
<div class="rr-dash-filehint rr-dash-no-drag">Drop an image here — or <<dash-paste-btn>> and press Ctrl+V — to add it as a tile</div>
<$transclude $variable="dash-tiles" containerId=<<containerId>> $mode="block"/>
</$file-dropzone>
</$let>
<%else%>
<$transclude $variable="dash-tiles" containerId=<<containerId>> $mode="block"/>
<%endif%>
</$droppable>
\end

<$let
	dashId={{{ [<currentTiddler>get[dashboard-id]] ~[<currentTiddler>] }}}
	hasFileUpload={{{ [[$:/plugins/rimir/file-upload]!is[missing]then[yes]] }}}
	hasKind={{{ [[$:/plugins/rimir/kind]!is[missing]then[yes]] }}}
	fitStateTid={{{ [<dashId>addprefix[$:/config/rimir/dashboard/]addsuffix[/fit]] }}}
	fitEnabled={{{ [<fitStateTid>get[text]match[yes]then[yes]] ~[[no]] }}}
	fitContentW={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>!has[dash-parent]] :map[get[x]add{!!w}] +[nsort[]last[]add[24]] ~[[0]] }}}
	fitContentH={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>!has[dash-parent]] :map[get[y]add{!!h}] +[nsort[]last[]add[24]] ~[[0]] }}}
	dashTilePasteActions="""<$action-createtiddler $basetitle={{{ [<fzTarget>function[dash.fz-title],<fzTarget>,<filename>] ~[<filename>] }}} _canonical_uri=<<canonical-uri>> _thumbnail_uri=<<generated-uri>> _content_hash=<<content-hash>> type=<<type>>>
<$action-createtiddler $basetitle={{{ [<dashId>addprefix[$:/config/rimir/dashboard/]addsuffix[/tiles/tile]] }}} tags="$:/tags/rimir/dashboard/tile" dashboard=<<dashId>> dash-parent=<<fzContainer>> target=<<createTiddler-title>> x="24" y="24" w="320" h="220" z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>get[z]nsort[]last[]add[1]] ~[[1]] }}}/>
</$action-createtiddler>"""
	dashGeomActions="""<$action-setfield $tiddler=<<currentTiddler>> x=<<new-x>> y=<<new-y>> w=<<new-w>> h=<<new-h>> z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard{!!dashboard}get[z]nsort[]last[]add[1]] ~[[1]] }}}/>"""
	dashReparentActions="""<$action-setfield $tiddler=<<currentTiddler>> dash-parent=<<new-parent>> x=<<new-x>> y=<<new-y>> w=<<new-w>> h=<<new-h>> z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard{!!dashboard}get[z]nsort[]last[]add[1]] ~[[1]] }}}/>"""
	dashCopyActions="""<$action-createtiddler $basetitle={{{ [<dashId>addprefix[$:/config/rimir/dashboard/]addsuffix[/tiles/tile]] }}} tags="$:/tags/rimir/dashboard/tile" dashboard=<<dashId>> dash-parent=<<new-parent>> target={{!!target}} style={{!!style}} x=<<new-x>> y=<<new-y>> w=<<new-w>> h=<<new-h>> z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard{!!dashboard}get[z]nsort[]last[]add[1]] ~[[1]] }}}/>"""
	dashOpenActions="""<$action-navigate $to={{!!target}}/>"""
	dashAddChildActions="""<$action-createtiddler $basetitle={{{ [<dashId>addprefix[$:/config/rimir/dashboard/]addsuffix[/tiles/tile]] }}} tags="$:/tags/rimir/dashboard/tile" dashboard=<<dashId>> dash-parent=<<containerId>> target=<<actionTiddler>> x="24" y="24" w="320" h="220" z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>get[z]nsort[]last[]add[1]] ~[[1]] }}}/>"""
	dashExpandAction="""<$action-setfield $tiddler=<<containerId>> collapsed="no" z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>get[z]nsort[]last[]add[1]] ~[[1]] }}}/>"""
	dashSizeActions="""<$action-setfield $tiddler=<<currentTiddler>> icon-w=<<new-icon-w>> icon-h=<<new-icon-h>>/>"""
	dashContextActions="""<$action-setfield $tiddler=<<currentTiddler>> dash-context=<<actionTiddler>> caption={{{ [<actionTiddler>get[caption]!is[blank]] ~[<actionTiddler>] }}}/>"""
	dashEmptyHint="""<div class="rr-dash-hint">Empty. Drop tiddlers here from the wiki, or drag a tile in from another container.</div>"""
>
<div class="rr-dash-root">
<div class="rr-dash-toolbar rr-dash-no-drag">
<$edit-text tiddler="$:/state/rimir/dashboard/add-target" tag="input" default="" placeholder="Tiddler title to add as a tile — or a name for a new group…" class="rr-dash-add-input tc-edit-texteditor"/>
<$button tooltip="Add a tile for the tiddler named above" aria-label="Add tile">
<$list filter="[{$:/state/rimir/dashboard/add-target}!is[blank]]" variable="ignore">
<$action-createtiddler $basetitle={{{ [<dashId>addprefix[$:/config/rimir/dashboard/]addsuffix[/tiles/tile]] }}} tags="$:/tags/rimir/dashboard/tile" dashboard=<<dashId>> target={{$:/state/rimir/dashboard/add-target}} x="24" y="24" w="320" h="220" z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>get[z]nsort[]last[]add[1]] ~[[1]] }}}/>
<$action-setfield $tiddler="$:/state/rimir/dashboard/add-target" text=""/>
</$list>
Add tile
</$button>
<$button tooltip="Add a group tile to organise other tiles into (uses the text above as its name, if any)" aria-label="Add group">
<$action-createtiddler $basetitle={{{ [<dashId>addprefix[$:/config/rimir/dashboard/]addsuffix[/tiles/tile]] }}} tags="$:/tags/rimir/dashboard/tile" role="group" dashboard=<<dashId>> caption={{$:/state/rimir/dashboard/add-target}} collapsed="no" x="24" y="24" w="300" h="240" z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>get[z]nsort[]last[]add[1]] ~[[1]] }}}>
<$action-setfield $tiddler="$:/state/rimir/dashboard/focus-group" text=<<createTiddler-title>>/>
</$action-createtiddler>
<$action-setfield $tiddler="$:/state/rimir/dashboard/add-target" text=""/>
Add group
</$button>
</div>
<div class="rr-dash-toolbar rr-dash-no-drag">
<$edit-text tiddler="$:/state/rimir/dashboard/add-filter" tag="input" default="" placeholder="Filter — add every matching tiddler as a tile…" class="rr-dash-filter-input tc-edit-texteditor"/>
<$button tooltip="Add a tile for every tiddler matching the filter above (laid out in a grid)" aria-label="Add matching tiles">
<$list filter="[{$:/state/rimir/dashboard/add-filter}!is[blank]]" variable="ignore">
<$list filter="[subfilter{$:/state/rimir/dashboard/add-filter}]" counter="n">
<$action-createtiddler $basetitle={{{ [<dashId>addprefix[$:/config/rimir/dashboard/]addsuffix[/tiles/tile]] }}} tags="$:/tags/rimir/dashboard/tile" dashboard=<<dashId>> target=<<currentTiddler>> x={{{ [<n>subtract[1]remainder[3]multiply[336]add[24]] }}} y={{{ [<n>subtract[1]divide[3]floor[]multiply[236]add[24]] }}} w="320" h="220" z={{{ [all[tiddlers]tag[$:/tags/rimir/dashboard/tile]field:dashboard<dashId>get[z]nsort[]last[]] ~[[0]] +[add<n>] }}}/>
</$list>
<$action-setfield $tiddler="$:/state/rimir/dashboard/add-filter" text=""/>
</$list>
Add matching
</$button>
</div>
<div class="rr-dash-toolbar rr-dash-no-drag">
<$edit-text tiddler="$:/state/rimir/dashboard/clean-filter" tag="input" default="" placeholder="Optional filter — which targets to remove (empty = all tiles)…" class="rr-dash-filter-input tc-edit-texteditor"/>
<$button class="rr-dash-clean-btn" tooltip="Remove tiles from this dashboard — all of them, or only those whose target matches the filter" aria-label="Clean dashboard">
<$action-setfield $tiddler="$:/state/rimir/dashboard/clean-confirm" text="yes"/>
Clean
</$button>
<<dash-clean-confirm>>
</div>
<div class="rr-dash-toolbar rr-dash-no-drag">
<$button tooltip="Per-dashboard display rules: map a target filter to the field each matching tile shows" aria-label="Toggle display rules">
<$action-setfield $tiddler="$:/state/rimir/dashboard/rules-open" text={{{ [{$:/state/rimir/dashboard/rules-open}match[yes]then[no]] ~[[yes]] }}}/>
Display rules
</$button>
<$button class={{{ [<fitEnabled>match[yes]then[rr-dash-fit-btn rr-dash-fit-on]] ~[[rr-dash-fit-btn]] }}} tooltip="Scale the whole board down so everything fits on screen at once — useful on a small display. Turn off to view at full size" aria-label="Toggle fit to screen">
<$action-setfield $tiddler=<<fitStateTid>> text={{{ [<fitEnabled>match[yes]then[no]] ~[[yes]] }}}/>
<%if [<fitEnabled>match[yes]] %>Fit to screen: on<%else%>Fit to screen: off<%endif%>
</$button>
<$button class={{{ [{$:/state/rimir/dashboard/fullscreen}match[yes]then[rr-dash-fit-btn rr-dash-fit-on]] ~[[rr-dash-fit-btn]] }}} tooltip="Show this dashboard fullscreen, using the whole screen (press again or Esc to exit). Combine with //Fit to screen// to see the entire board at once" aria-label="Toggle fullscreen">
<$action-rr-dash-fullscreen/>
<%if [{$:/state/rimir/dashboard/fullscreen}match[yes]] %>⛶ Exit fullscreen<%else%>⛶ Fullscreen<%endif%>
</$button>
</div>
<<dash-rules-editor>>
<$dashboard-fit enabled=<<fitEnabled>> content-width=<<fitContentW>> content-height=<<fitContentH>>>
<$transclude $variable="dash-canvas" containerId="" $mode="block"/>
</$dashboard-fit>
<<dash-popup>>
<<dash-icon-editor>>
<<dash-context-editor>>
</div>
</$let>
