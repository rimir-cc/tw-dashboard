title: $:/plugins/rimir/dashboard/body

\whitespace trim

<!-- File-upload location resolution. Given a "location target" (a content tile's
     target, or a group's dash-context), map its first path segment to a configured
     file-upload location (tag $:/tags/rimir/file-upload/location). This generalises
     the old hard-coded work/ handling: any tiddler whose namespace matches a
     configured location name is stored in that scattered location; everything else
     falls back to the default files location. -->
\function dash.fz-name(loctarget) [all[tiddlers+shadows]tag[$:/tags/rimir/file-upload/location]get[text]jsonget[name]] :filter[<loctarget>split[/]first[]match<currentTiddler>] +[first[]]
\function dash.fz-location(loctarget) [all[tiddlers+shadows]tag[$:/tags/rimir/file-upload/location]get[text]jsonget[name]] :filter[<loctarget>split[/]first[]match<currentTiddler>] +[first[]] ~[[files]]
\function dash.fz-subfolder(loctarget) [all[tiddlers+shadows]tag[$:/tags/rimir/file-upload/location]get[text]jsonget[name]] :filter[<loctarget>split[/]first[]match<currentTiddler>] :map[<loctarget>removeprefix<currentTiddler>removeprefix[/]] +[first[]]
\function dash.fz-title(loctarget,fname) [all[tiddlers+shadows]tag[$:/tags/rimir/file-upload/location]get[text]jsonget[name]] :filter[<loctarget>split[/]first[]match<currentTiddler>] :map[<loctarget>addsuffix[/]addsuffix<fname>] +[first[]] ~[<fname>]

<!-- Shared "arm paste" affordance. A plain (action-less) focusable button that
     lives INSIDE a <$file-dropzone>: clicking it takes focus (the drag widget
     ignores .rr-dash-no-drag without preventDefault, so the browser focuses it),
     then Ctrl+V fires a paste event that bubbles up to the enclosing dropzone,
     which uploads the clipboard image to that tile/group's fs location. -->
\procedure dash-paste-btn()
<button type="button" class="rr-dash-paste-btn rr-dash-no-drag" title="Click to arm, then press Ctrl+V to paste an image from the clipboard here" aria-label="Arm clipboard paste">&#128203;</button>
\end

<!-- Kind entity-actions (✎) menu, shared by content tiles and context-linked
     groups. Reads two vars from the caller's scope:
       emenuEntity  the kind instance to act on (a tile's target, or a group's
                    dash-context); renders nothing when blank or not a kind type
       emenuCtxB    the `dash-parent` for the tile dropped by an "Add child" —
                    a content tile passes its own group; a group passes itself,
                    so the new child's tile lands inside it -->
\procedure dash-emenu()
<$list filter="[<hasKind>match[yes]]" variable="ignore">
<$list filter="[<emenuEntity>has[kind.type]]" variable="ignore">
<$let ea-entity=<<emenuEntity>>
	ea-after-create="dashboard.kind-add-child-hook"
	ea-ctx-a=<<dashId>>
	ea-ctx-b=<<emenuCtxB>>>
<span class="rr-dash-menu rr-dash-emenu rr-dash-no-drag">
<button type="button" class="rr-dash-ctl rr-dash-menu-trigger" title="Entity actions — edit fields / add a child" aria-label="Entity actions">&#9998;</button>
<span class="rr-dash-menu-items rr-dash-emenu-items">
<$transclude $tiddler="$:/plugins/rimir/kind/entity-actions" $mode="block"/>
</span>
</span>
</$let>
</$list>
</$list>
\end

\procedure dash-controls()
<$let emenuEntity={{!!target}} emenuCtxB={{!!dash-parent}}><<dash-emenu>></$let>
<$list filter="[<tileExtUrl>!is[blank]]" variable="ignore">
<a class="rr-dash-ctl rr-dash-no-drag" href=<<tileExtUrl>> target="_blank" rel="noopener noreferrer" title="Open link in a new browser tab (or Ctrl/Cmd-click the tile)" aria-label="Open link in a new tab">↗</a>
</$list>
<span class="rr-dash-menu rr-dash-no-drag">
<button type="button" class="rr-dash-ctl rr-dash-menu-trigger" title="Tile actions" aria-label="Tile actions">⋮</button>
<span class="rr-dash-menu-items">
<$list filter="[<tileExtUrl>] ~[[]] +[is[blank]]" variable="ignore">
<a class="rr-dash-ctl" href={{{ [<tileTargetTitle>encodeuricomponent[]addprefix[#]] }}} target="_blank" rel="noopener noreferrer" title="Open this tiddler in a new browser tab (its permalink)" aria-label="Open in a new browser tab">↗</a>
</$list>
<$button class="rr-dash-ctl" tooltip="Show the tiddler's contents in a popup" aria-label="Show contents">
<$action-setfield $tiddler="$:/state/rimir/dashboard/popup" text={{!!target}}/>
⧉
</$button>
<$button class="rr-dash-ctl" tooltip="Toggle tile style (window / bare)" aria-label="Toggle tile style">
<$action-setfield $tiddler=<<currentTiddler>> style={{{ [{!!style}match[bare]then[window]] ~[[bare]] }}}/>
⊟
</$button>
<$button class="rr-dash-ctl" tooltip="Remove this tile from the dashboard" aria-label="Remove tile">
<$action-deletetiddler $tiddler=<<currentTiddler>>/>
×
</$button>
<span class="rr-dash-menu-sep"></span>
<span class="rr-dash-menu-showlabel">Show</span>
<span class="rr-dash-menu-row">
<$button class="rr-dash-ctl" tooltip="Show automatically: the body when the tiddler has text, otherwise its icon" aria-label="Show automatic">
<$action-deletefield $tiddler=<<currentTiddler>> $field="display"/>
auto
</$button>
<$button class="rr-dash-ctl" tooltip="Show the tiddler's body" aria-label="Show body">
<$action-setfield $tiddler=<<currentTiddler>> display="text"/>
body
</$button>
<$button class="rr-dash-ctl" tooltip="Show the tiddler's icon" aria-label="Show icon">
<$action-setfield $tiddler=<<currentTiddler>> display="icon"/>
icon
</$button>
</span>
<$edit-text tiddler=<<currentTiddler>> field="display" tag="input" default="" placeholder="…or a field name" class="rr-dash-menu-input tc-edit-texteditor"/>
</span>
</span>
\end

<!-- Context chip in a group header: a drop target that links the group to a
     tiddler as its "implicit context". Empty = a faint link glyph inviting a
     drop; linked = the context's kind icon (or a link glyph) — click to open the
     tiddler in the story river, drop another tiddler to relink. Dropping copies
     the tiddler's caption to the group (see dashContextActions). Lives inside the
     move handle but is rr-dash-no-drag so a click opens rather than moving. Reads
     <<groupContext>> from the group tile's scope. -->
\procedure dash-group-context()
<%if [<groupContext>!is[blank]] %>
<$let ctxTypeKey={{{ [<groupContext>get[kind.type]] }}}
	ctxIcon={{{ [all[shadows+tiddlers]has[kind.fields]field:kind.type<ctxTypeKey>has[kind.icon]get[kind.icon]first[]] }}}
	ctxLabel={{{ [<groupContext>get[caption]!is[blank]] ~[<groupContext>] }}}>
<$button class="rr-dash-ctl rr-dash-ctx-link rr-dash-no-drag" tooltip={{{ [<ctxLabel>addprefix[Context: ]addsuffix[  -  click to open in the story river; drop a tiddler on the header to relink]] }}} aria-label="Open the context tiddler">
<$action-navigate $to=<<groupContext>>/>
<%if [<ctxIcon>!is[blank]] %>
<span class="rr-dash-kind-icon"><$text text=<<ctxIcon>>/></span>
<%else%>
<span class="rr-dash-ctx-glyph">&#128279;</span>
<%endif%>
</$button>
</$let>
<%else%>
<span class="rr-dash-ctx-empty" title="Drop a tiddler onto this header to link the group to it as its context (adopts its caption, shows its kind icon, and enables entity actions)">&#128279;</span>
<%endif%>
\end

\procedure dash-group-controls()
